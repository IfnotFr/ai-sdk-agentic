{
  "name": "ai-sdk-agentic",
  "version": "1.0.0",
  "description": "Orchestration layer for Vercel AI SDK agents: shared context, mission lifecycle hooks, and tool wrapping.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "sdk",
    "vercel",
    "agents",
    "agentic",
    "orchestration",
    "context",
    "hooks",
    "toolloop"
  ],
  "author": "Anael Favre",
  "license": "MIT",
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^6.0.134",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0",
    "zod": "^3.23.8"
  }
}
